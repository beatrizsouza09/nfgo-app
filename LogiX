<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NfGo - Sistema Logístico Completo com Bluetooth</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --bg-color: #0d1117;
            --card-bg: #161b22;
            --accent: #238636;
            --accent-hover: #2ea043;
            --text-main: #f0f6fc;
            --text-sub: #8b949e;
            --border: #30363d;
            --blue: #2f81f7;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }

        body {
            background-color: #010409;
            color: var(--text-main);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .mobile-frame {
            width: 100%;
            max-width: 400px;
            height: 780px;
            background-color: var(--bg-color);
            border: 8px solid #21262d;
            border-radius: 40px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
            box-shadow: 0 20px 50px rgba(0,0,0,0.8);
        }

        .status-bar {
            height: 40px;
            background-color: var(--card-bg);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            font-size: 12px;
            color: var(--text-sub);
            border-bottom: 1px solid var(--border);
        }

        .screen-container {
            flex: 1;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow-y: auto;
        }

        .screen { display: none; flex-direction: column; height: 100%; justify-content: space-between; }
        .screen.active { display: flex; }

        .step-tag {
            background: rgba(35, 134, 54, 0.15);
            color: #3fb950;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            width: fit-content;
            margin-bottom: 12px;
        }

        .bt-badge {
            background: rgba(47, 129, 247, 0.15);
            color: var(--blue);
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            margin-bottom: 10px;
        }

        h2 { font-size: 22px; margin-bottom: 8px; color: var(--text-main); }
        p { font-size: 14px; color: var(--text-sub); line-height: 1.5; }

        .input-group { margin-top: 15px; text-align: left; }
        .input-group label { display: block; font-size: 12px; color: var(--text-sub); margin-bottom: 5px; }
        .input-group input { width: 100%; padding: 12px; background: var(--bg-color); border: 1px solid var(--border); border-radius: 8px; color: var(--text-main); font-size: 14px; }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            margin: 15px 0;
            text-align: center;
        }

        .card-icon { font-size: 44px; color: #3fb950; margin-bottom: 12px; }

        .watch-box {
            width: 140px;
            height: 140px;
            background: #000;
            border: 3px solid var(--blue);
            border-radius: 35px;
            margin: 10px auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 10px;
            text-align: center;
            box-shadow: 0 0 15px rgba(47, 129, 247, 0.2);
        }

        .btn {
            background-color: var(--accent);
            color: white;
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            transition: 0.2s;
        }

        .btn:hover { background-color: var(--accent-hover); }

        .stars { display: flex; justify-content: center; gap: 10px; margin: 20px 0; }
        .stars i { font-size: 32px; color: var(--border); cursor: pointer; }
        .stars i.active { color: #f1e05a; }

        .bottom-nav {
            height: 60px;
            background-color: var(--card-bg);
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-around;
            align-items: center;
        }

        .nav-item { color: var(--text-sub); font-size: 18px; cursor: pointer; }
        .nav-item.active { color: #3fb950; }
    </style>
</head>
<body>

<div class="mobile-frame">
    <div class="status-bar">
        <span>09:41</span>
        <div>
            <i class="fa-solid fa-bluetooth" style="color: var(--blue);"></i>
            <i class="fa-solid fa-wifi"></i>
            <i class="fa-solid fa-battery-full"></i>
        </div>
    </div>

    <div class="screen-container">

        <div class="screen active" id="step-0">
            <div>
                <div style="text-align: center; margin-top: 20px;">
                    <i class="fa-solid fa-nfc-symbol" style="font-size: 50px; color: #3fb950;"></i>
                    <h2 style="margin-top: 15px;">NfGo Logística</h2>
                    <p>Acesse o sistema operacional</p>
                </div>
                
                <div class="card">
                    <div class="input-group">
                        <label>Usuário / E-mail</label>
                        <input type="text" value="operador@nfgo.com">
                    </div>
                    <div class="input-group">
                        <label>Senha</label>
                        <input type="password" value="123456">
                    </div>
                </div>
            </div>
            <button class="btn" onclick="nextStep(1)">
                <i class="fa-solid fa-right-to-bracket"></i> Entrar no Sistema
            </button>
        </div>

        <div class="screen" id="step-1">
            <div>
                <span class="step-tag">Etapa 1 de 5</span>
                <h2>1. Vinculação Nota/Tag</h2>
                <p>Gravação dos dados da Nota Fiscal no chip NFC colado na caixa.</p>
                <div class="card">
                    <div class="card-icon"><i class="fa-solid fa-file-invoice"></i></div>
                    <h3>Pedido #NF-8921</h3>
                    <p style="margin-top: 8px;">Produto: Smartphone Galaxy</p>
                    <p>Status: Aguardando gravação NFC</p>
                </div>
            </div>
            <button class="btn" onclick="nextStep(2)">
                <i class="fa-solid fa-nfc-symbol"></i> Gravar Tag na Caixa
            </button>
        </div>

        <div class="screen" id="step-2">
            <div>
                <span class="step-tag">Etapa 2 de 5</span>
                <div class="bt-badge"><i class="fa-solid fa-bluetooth"></i> Smartwatch Conectado (BLE)</div>
                <h2>2. Conferência no Pulso</h2>
                <p>O relógio lê a tag NFC na caixa e envia os dados instantaneamente para o aplicativo no celular via Bluetooth.</p>
                
                <div class="watch-box">
                    <i class="fa-solid fa-stopwatch" style="font-size: 26px; color: var(--blue);"></i>
                    <span style="font-size: 10px; color: #fff; margin-top: 5px;">NfGo Watch App</span>
                    <span id="watch-msg" style="font-size: 11px; color: #3fb950; font-weight: bold; margin-top: 8px;">Aproxime a caixa</span>
                </div>

                <div class="card" style="margin-top: 5px;">
                    <p id="phone-msg" style="font-size: 12px;">Status do App: Conexão BLE OK. Aguardando leitura NFC no relógio...</p>
                </div>
            </div>

            <button class="btn" onclick="simularLeituraBLE()">
                <i class="fa-solid fa-wifi"></i> Simular Bip no Relógio
            </button>
        </div>

        <div class="screen" id="step-3">
            <div>
                <span class="step-tag">Etapa 3 de 5</span>
                <h2>3. Checagem do Motorista</h2>
                <p>O entregador bipe as caixas com o smartphone no momento do carregamento no veículo.</p>
                <div class="card">
                    <div class="card-icon"><i class="fa-solid fa-truck-ramp-box"></i></div>
                    <h3>Validação de Rota</h3>
                    <p style="margin-top: 8px;">Rota #04 - Zona Sul</p>
                    <p id="truck-status" style="color: #3fb950; font-weight: bold; margin-top: 5px;">Aguardando validação...</p>
                </div>
            </div>
            <button class="btn" onclick="scanDriverNFC()">
                <i class="fa-solid fa-mobile-screen-button"></i> Bipar Pacote no Veículo
            </button>
        </div>

        <div class="screen" id="step-4">
            <div>
                <span class="step-tag">Etapa 4 de 5</span>
                <h2>4. Recebimento do Cliente</h2>
                <p>O cliente aproxima seu próprio smartphone do pacote para atestar a entrega.</p>
                <div class="card">
                    <div class="card-icon"><i class="fa-solid fa-circle-check"></i></div>
                    <h3>Pacote Autêntico</h3>
                    <p style="margin-top: 8px;">Entrega confirmada com sucesso!</p>
                </div>
            </div>
            <button class="btn" onclick="nextStep(5)">
                <i class="fa-solid fa-arrow-right"></i> Ir para Avaliação
            </button>
        </div>

        <div class="screen" id="step-5">
            <div>
                <span class="step-tag">Etapa 5 de 5</span>
                <h2>5. Avaliação do Serviço</h2>
                <p>Sua nota ajuda a melhorar a qualidade das nossas entregas.</p>
                <div class="card">
                    <h3>Nota da Entrega</h3>
                    <div class="stars">
                        <i class="fa-solid fa-star" onclick="rate(1)"></i>
                        <i class="fa-solid fa-star" onclick="rate(2)"></i>
                        <i class="fa-solid fa-star" onclick="rate(3)"></i>
                        <i class="fa-solid fa-star" onclick="rate(4)"></i>
                        <i class="fa-solid fa-star" onclick="rate(5)"></i>
                    </div>
                </div>
            </div>
            <button class="btn" onclick="finishFlow()">
                <i class="fa-solid fa-paper-plane"></i> Finalizar Pedido
            </button>
        </div>

    </div>

    <div class="bottom-nav">
        <i class="fa-solid fa-user nav-item active" onclick="nextStep(0)"></i>
        <i class="fa-solid fa-file-invoice nav-item" onclick="nextStep(1)"></i>
        <i class="fa-solid fa-stopwatch nav-item" onclick="nextStep(2)"></i>
        <i class="fa-solid fa-truck nav-item" onclick="nextStep(3)"></i>
        <i class="fa-solid fa-mobile nav-item" onclick="nextStep(4)"></i>
        <i class="fa-solid fa-star nav-item" onclick="nextStep(5)"></i>
    </div>
</div>

<script>
    function nextStep(stepNumber) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById('step-' + stepNumber).classList.add('active');

        const navItems = document.querySelectorAll('.nav-item');
        navItems.forEach(item => item.classList.remove('active'));
        if (navItems[stepNumber]) {
            navItems[stepNumber].classList.add('active');
        }
    }

    function simularLeituraBLE() {
        const watchMsg = document.getElementById('watch-msg');
        const phoneMsg = document.getElementById('phone-msg');
        
        watchMsg.innerText = "Lendo Tag...";
        watchMsg.style.color = "#fbbf24";
        phoneMsg.innerText = "Sinal Bluetooth Recebido! Validando no Banco de Dados...";
        
        setTimeout(() => {
            watchMsg.innerText = "✔ CONFERIDO";
            watchMsg.style.color = "#3fb950";
            phoneMsg.innerText = "Produto
